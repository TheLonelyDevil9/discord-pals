# Discord Pals environment example
# Copy to .env for local runs, or provide the same keys through Docker,
# Compose, systemd, or your host shell. Never commit real tokens or API keys.

# ============================================
# SINGLE-BOT MODE
# ============================================
# Used only when bots.json does not exist.
# Get a Discord bot token at:
# https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Character filename without .md from characters/.
# Example: characters/firefly.md -> DEFAULT_CHARACTER=firefly
DEFAULT_CHARACTER=firefly

# ============================================
# MULTI-BOT MODE
# ============================================
# Used when bots.json exists. Add one variable for each bots.json token_env.
# These names match bots.json.example. Rename or add keys to match your bots.
# DISCORD_TOKEN is ignored while bots.json is present.
FIREFLY_DISCORD_TOKEN=token_for_firefly_bot
GEORGE_DISCORD_TOKEN=token_for_george_bot

# ============================================
# AI PROVIDER API KEYS
# ============================================
# providers.json selects key names with key_env. Only keys used by your active
# provider entries need real values.

# OpenAI / OpenAI-compatible examples and image generation.
OPENAI_API_KEY=your_openai_api_key

# OpenRouter examples, including Claude via OpenRouter.
OPENROUTER_API_KEY=your_openrouter_api_key

# DeepSeek examples.
DEEPSEEK_API_KEY=your_deepseek_api_key

# Z.AI / GLM examples.
ZAI_API_KEY=your_zai_api_key

# Moonshot / Kimi examples.
MOONSHOT_API_KEY=your_moonshot_api_key

# Local LLM providers that do not require auth can keep this placeholder.
LOCAL_API_KEY=not-needed

# Custom provider examples from providers.json.example.
EXAMPLE_API_KEY=your_example_provider_api_key
NEWAPI_API_KEY=your_newapi_provider_api_key

# Add any extra provider key_env names here.
# MY_PROVIDER_API_KEY=your_provider_key

# ============================================
# DASHBOARD SECURITY
# ============================================
# DASHBOARD_PASS enables dashboard authentication.
# DASHBOARD_USER defaults to admin when DASHBOARD_PASS is set.
# Leave DASHBOARD_PASS blank/unset only on trusted local/private networks.
DASHBOARD_USER=admin
DASHBOARD_PASS=
